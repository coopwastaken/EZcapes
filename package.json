{
  "name": "ezcapes",
  "version": "1.5.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.mctools.ezcapes",
    "productName": "EZCAPES",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "coopwastaken",
      "repo": "EZcapes"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "web/**/*",
      "node_modules/jszip/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
